# Local development defaults. Copy to .env and override as needed.

POSTGRES_DB=nakama
POSTGRES_USER=postgres
POSTGRES_PASSWORD=localdb

VITE_NAKAMA_HOST=localhost
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_SCHEME=http

# Nakama's client-visible server key for this local sample.
# Replace alongside nakama/local.yml before any shared or production deployment.
NAKAMA_CLIENT_PUBLIC=defaultkey
